{
  "expo": {
    "name": "Paperclip",
    "slug": "paperclip",
    "version": "0.0.7",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.paperclip.mobile"
    },
    "android": {
      "package": "ai.paperclip.mobile"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ]
    ]
  }
}