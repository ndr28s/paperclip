{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "react": ["./node_modules/react"],
      "@types/react": ["./node_modules/@types/react"]
    }
  },
  "include": ["App.tsx", "index.ts", "src", "**/*.ts", "**/*.tsx"]
}
