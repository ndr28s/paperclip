# Default: let Git detect text/binary. Normalize text to LF in the repo.
* text=auto eol=lf

# Shell scripts MUST stay LF even on Windows checkouts (otherwise bash won't run them).
*.sh     text eol=lf
*.bash   text eol=lf

# Scripts and source stay LF — matches macOS/Linux dev experience.
*.mjs    text eol=lf
*.cjs    text eol=lf
*.js     text eol=lf
*.jsx    text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.toml   text eol=lf
*.md     text eol=lf

# Windows-native files may keep CRLF
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf

# Common binaries — leave untouched.
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.zip    binary
*.tar    binary
*.gz     binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.eot    binary
