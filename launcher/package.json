{
  "name": "paperclip-launcher",
  "version": "1.0.0",
  "description": "Paperclip Windows Tray Launcher",
  "author": "Paperclip",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-packager . Paperclip --platform=win32 --arch=x64 --out=dist --overwrite --electron-version=34.5.8 --extra-resource=dist/server",
    "build:installer": "electron-builder --win",
    "build:standalone": "node scripts/build-standalone.mjs"
  },
  "dependencies": {
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@electron/packager": "^18.3.5",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "ai.paperclip.launcher",
    "productName": "Paperclip",
    "asar": false,
    "win": {
      "target": "nsis",
      "signingHashAlgorithms": null,
      "icon": "src/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "extraResources": [
      {
        "from": "../",
        "to": "app",
        "filter": [
          "server/dist/**",
          "cli/dist/**",
          "packages/**/dist/**",
          ".paperclip/**"
        ]
      }
    ]
  }
}
